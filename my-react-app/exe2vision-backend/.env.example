DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/exe2vision
SECRET_KEY=supersecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# N-gram image settings
NGRAMS_DIR=ngram_files_colored
NGRAMS_OUTPUT_DIR=./output_images
NGRAM_IMAGE_WIDTH=825
NGRAM_SLOTS_PER_LINE=17

# Optional: path to external exetoassembly tool
# EXE_TO_ASM_PATH=C:\tools\exetoassembly.exe
# EXE_TO_ASM_TIMEOUT=30

# Optional: ML model path (default: resnet.pth in backend root)
# MODEL_PATH=resnet.pth
